{
  "name": "qa-enginner",
  "version": "1.0.0",
  "description": "Projeto de automação de testes web com Cypress, Page Object, API tests, Mochawesome e GitHub Actions.",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:e2e": "cypress run --spec 'cypress/e2e/*.cy.js'",
    "test:api": "cypress run --spec 'cypress/e2e/api.cy.js'",
    "report:clean": "npx rimraf mochawesome-report cypress/reports",
    "report:run": "cypress run --reporter mochawesome",
    "report:open": "start mochawesome-report/mochawesome.html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Luizin16/Qa-Enginner.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Luizin16/Qa-Enginner/issues"
  },
  "homepage": "https://github.com/Luizin16/Qa-Enginner#readme",
  "devDependencies": {
    "cypress": "^15.12.0"
  }
}
